#!/usr/bin/env python3
"""
Saturn Fan Auto-Calibration + Control
Detects active fans, calibrates PWM limits, then runs a temperature-based
fan control loop. Replaces the fancontrol system package.

Caches calibration results to skip on subsequent boots unless fan config changes.
"""
import time, sys, os, json, glob, signal

FAN_DEVICE = "/sys/devices/platform/f71882fg.2592"
CACHE_FILE  = "/etc/saturn-fan-cache.json"

# Temperature control curve
TEMP_MIN  = 30   # °C — below this: MINPWM
TEMP_MAX  = 70   # °C — above this: 255
INTERVAL  = 10   # seconds between adjustments

_running = True

def _sig(s, f):
    global _running
    _running = False

signal.signal(signal.SIGTERM, _sig)
signal.signal(signal.SIGINT,  _sig)


# ── sysfs helpers ────────────────────────────────────────────────────────────

def read_file(path):
    try:
        with open(path) as f:
            return f.read().strip()
    except:
        return None

def write_file(path, val):
    try:
        with open(path, "w") as f:
            f.write(str(val))
        return True
    except OSError as e:
        print(f"    WARN: cannot write {path}={val}: {e}")
        return False

def fan_path(ch, attr):
    return f"{FAN_DEVICE}/{attr}{ch}_input" if attr in ("fan",) else f"{FAN_DEVICE}/{attr}{ch}"

def read_rpm(ch):
    v = read_file(f"{FAN_DEVICE}/fan{ch}_input")
    return int(v) if v else 0

def read_pwm(ch):
    v = read_file(f"{FAN_DEVICE}/pwm{ch}")
    return int(v) if v else 0

def set_manual(ch):
    write_file(f"{FAN_DEVICE}/pwm{ch}_enable", "1")
    time.sleep(0.2)

def set_auto(ch):
    write_file(f"{FAN_DEVICE}/pwm{ch}_enable", "2")

def set_pwm(ch, val):
    write_file(f"{FAN_DEVICE}/pwm{ch}", str(val))


# ── temperature sensor ────────────────────────────────────────────────────────

def find_temp_path():
    """Find coretemp CPU package temp (temp1_input = package)."""
    for path in glob.glob("/sys/class/hwmon/hwmon*"):
        try:
            name = open(f"{path}/name").read().strip()
        except:
            continue
        if name == "coretemp":
            t = f"{path}/temp1_input"
            if os.path.exists(t):
                return t
    return None

def read_temp_c(path):
    v = read_file(path)
    return int(v) // 1000 if v else 0


# ── fan detection ─────────────────────────────────────────────────────────────

def detect_active_channels():
    """Return list of fan channels that have fans connected."""
    active = []
    for ch in [1, 2, 3]:
        rpm = read_rpm(ch)
        if rpm > 0:
            active.append(ch)
            continue
        set_manual(ch)
        set_pwm(ch, 255)
        time.sleep(4)
        rpm = read_rpm(ch)
        if rpm > 0:
            active.append(ch)
        set_auto(ch)
    return active


# ── cache ─────────────────────────────────────────────────────────────────────

def load_cache():
    try:
        with open(CACHE_FILE) as f:
            return json.load(f)
    except:
        return None

def save_cache(data):
    with open(CACHE_FILE, "w") as f:
        json.dump(data, f, indent=2)


# ── calibration ───────────────────────────────────────────────────────────────

def calibrate_fan(ch):
    """Find MINSTART, MINSTOP and max RPM for a fan channel."""
    print(f"\n=== Calibrating Fan{ch} ===")
    result = {}

    set_manual(ch)

    # Max RPM
    set_pwm(ch, 255)
    time.sleep(4)
    result["max_rpm"] = read_rpm(ch)
    print(f"  Max RPM (PWM 255): {result['max_rpm']}")

    # Find MINSTOP — decrease until stall
    print("  Finding minimum PWM before stall...")
    minstop = 255
    for pwm in range(120, 20, -5):
        set_pwm(ch, pwm)
        time.sleep(3)
        rpm = read_rpm(ch)
        if rpm > 0:
            minstop = pwm
            print(f"    PWM {pwm}: {rpm} RPM")
        else:
            print(f"    PWM {pwm}: STALLED")
            break

    result["minstop"] = min(minstop + 10, 255)
    print(f"  MINSTOP: {result['minstop']} (with +10 margin)")

    # Find MINSTART — from stall, increase until spinning
    print("  Finding minimum PWM to restart from standstill...")
    set_pwm(ch, 0)
    time.sleep(2)
    minstart = 255
    for pwm in range(50, 256, 5):
        set_pwm(ch, pwm)
        time.sleep(3)
        rpm = read_rpm(ch)
        if rpm > 0:
            minstart = pwm
            print(f"    PWM {pwm}: started ({rpm} RPM)")
            break
        else:
            print(f"    PWM {pwm}: still stalled")

    result["minstart"] = min(minstart + 10, 255)
    print(f"  MINSTART: {result['minstart']} (with +10 margin)")

    # RPM at safe minimum
    set_pwm(ch, result["minstop"])
    time.sleep(3)
    result["min_rpm"] = read_rpm(ch)
    print(f"  Min RPM (PWM {result['minstop']}): {result['min_rpm']}")

    set_pwm(ch, 160)
    return result


def run_calibration(force=False):
    """Run calibration if needed. Returns {ch: data} dict."""
    print("Saturn Fan Calibration")
    print("=" * 40)

    cache = load_cache()
    active = detect_active_channels()

    if not active:
        print("No fans detected. Exiting.")
        sys.exit(1)

    if not force and cache is not None:
        cached_ch = sorted([int(c) for c in cache.get("channels", [])])
        if sorted(active) == cached_ch and os.path.exists(CACHE_FILE):
            print(f"Fan config unchanged (channels {active}) — using cached calibration")
            return {int(k): v for k, v in cache["fans"].items()}

    if force:
        print("Forced recalibration")
    else:
        print(f"Fan config changed or no cache — calibrating channels {active}")

    fans_data = {}
    for ch in active:
        fans_data[ch] = calibrate_fan(ch)

    print("\n" + "=" * 40)
    print("RESULTS:")
    for ch, data in fans_data.items():
        print(f"  Fan{ch}: {data['min_rpm']}–{data['max_rpm']} RPM, "
              f"PWM {data['minstop']}–255, kickstart at {data['minstart']}")

    cache_data = {"channels": active, "fans": {str(ch): d for ch, d in fans_data.items()}}
    save_cache(cache_data)
    print(f"Calibration cached to {CACHE_FILE}")

    return fans_data


# ── fan control loop ──────────────────────────────────────────────────────────

def pwm_for_temp(temp, minpwm, temp_min=TEMP_MIN, temp_max=TEMP_MAX):
    """Linear interpolation: temp → PWM value."""
    if temp <= temp_min:
        return minpwm
    if temp >= temp_max:
        return 255
    ratio = (temp - temp_min) / (temp_max - temp_min)
    return int(minpwm + ratio * (255 - minpwm))


def run_control(fans_data, temp_path):
    """Temperature-based fan control loop."""
    print("\nStarting fan control loop")
    print(f"  Temp sensor : {temp_path}")
    print(f"  Curve       : {TEMP_MIN}°C → MINPWM, {TEMP_MAX}°C → 255")
    print(f"  Interval    : {INTERVAL}s")

    # Set all fans to manual
    for ch in fans_data:
        set_manual(ch)

    prev_pwm = {}

    while _running:
        temp = read_temp_c(temp_path)

        for ch, data in fans_data.items():
            minpwm   = data["minstop"]
            minstart = data["minstart"]
            target   = pwm_for_temp(temp, minpwm)
            current  = prev_pwm.get(ch, read_pwm(ch))

            # If fan was stopped and target > 0, kick-start first
            if current < data["minstop"] and target > 0:
                set_pwm(ch, minstart)
                time.sleep(1)

            set_pwm(ch, target)
            prev_pwm[ch] = target

        time.sleep(INTERVAL)

    # On exit, restore auto mode
    print("\nShutting down — restoring auto mode")
    for ch in fans_data:
        set_auto(ch)


# ── entry point ───────────────────────────────────────────────────────────────

def main():
    force = "--force" in sys.argv
    calibrate_only = "--calibrate-only" in sys.argv

    temp_path = find_temp_path()
    if not temp_path:
        print("ERROR: coretemp not found. Is coretemp module loaded?")
        sys.exit(1)

    fans_data = run_calibration(force=force)

    if calibrate_only:
        print("Calibration done (--calibrate-only). Exiting.")
        return

    run_control(fans_data, temp_path)


if __name__ == "__main__":
    main()
