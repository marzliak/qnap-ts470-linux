#!/usr/bin/env python3
"""
Saturn LCD Monitor
QNAP TS-470 Pro ICP A125 LCD display with auto-rotate and button navigation.
Protocol: /dev/ttyS1 @ 1200 baud 8N1, 0x4D command prefix
"""
import os, time, termios, subprocess, glob

PORT = "/dev/ttyS1"
PAGE_TIME = 5
DETAIL_TIMEOUT = 15
HW_REFRESH = 10
SCREEN_TIMEOUT = 600
TRIPLE_WINDOW = 1.5
FAN_HWMON = "/sys/devices/platform/f71882fg.2592"

def setup_serial(port):
    fd = os.open(port, os.O_RDWR | os.O_NOCTTY | os.O_NONBLOCK)
    attrs = termios.tcgetattr(fd)
    attrs[0] = 0
    attrs[1] = 0
    attrs[2] = termios.CS8 | termios.CREAD | termios.CLOCAL
    attrs[3] = 0
    attrs[4] = termios.B1200
    attrs[5] = termios.B1200
    attrs[6][termios.VMIN] = 0
    attrs[6][termios.VTIME] = 0
    termios.tcsetattr(fd, termios.TCSANOW, attrs)
    return fd

def lcd_write(fd, line1, line2):
    l1 = f"{line1:<16.16s}".encode()
    l2 = f"{line2:<16.16s}".encode()
    os.write(fd, b'\x4d\x0c\x00\x10' + l1)
    time.sleep(0.18)
    os.write(fd, b'\x4d\x0c\x01\x10' + l2)
    time.sleep(0.18)

def lcd_backlight(fd, on):
    os.write(fd, b'\x4d\x5e' + bytes([0x01 if on else 0x00]))
    time.sleep(0.05)

def read_button(fd):
    try:
        data = os.read(fd, 64)
        for i in range(len(data) - 3):
            if data[i] == 0x53 and data[i+1] == 0x05 and data[i+2] == 0x00:
                return data[i+3]
    except (BlockingIOError, OSError):
        pass
    return None

def sh(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, stderr=subprocess.DEVNULL).decode().strip()
    except:
        return ""

def fmt_thousands(val):
    try:
        s = str(int(val))
        result = []
        for i, c in enumerate(reversed(s)):
            if i > 0 and i % 3 == 0:
                result.append('.')
            result.append(c)
        return ''.join(reversed(result))
    except:
        return val

def fmt_bytes(n):
    try:
        n = int(n)
        if n >= 1_000_000_000:
            return f"{n/1_000_000_000:.1f}G"
        elif n >= 1_000_000:
            return f"{n/1_000_000:.1f}M"
        elif n >= 1_000:
            return f"{n/1_000:.0f}K"
        return f"{n}B"
    except:
        return "0"

def read_cpu_ticks():
    with open("/proc/stat") as f:
        parts = f.readline().split()
    vals = [int(x) for x in parts[1:8]]
    idle = vals[3] + vals[4]
    total = sum(vals)
    return idle, total

def find_hwmon(name):
    """Find hwmon path by chip name (hwmon numbers can change between boots)"""
    for hwmon_dir in sorted(glob.glob("/sys/class/hwmon/hwmon*")):
        try:
            with open(os.path.join(hwmon_dir, "name")) as f:
                if f.read().strip() == name:
                    return hwmon_dir
        except:
            continue
    return None

HWMON_CORETEMP = find_hwmon("coretemp") or "/sys/class/hwmon/hwmon2"
HWMON_ACPI = find_hwmon("acpitz") or "/sys/class/hwmon/hwmon0"
HWMON_NIC = find_hwmon("r8169_0_100:00") or "/sys/class/hwmon/hwmon1"

def read_fan(n):
    try:
        with open(f"{FAN_HWMON}/fan{n}_input") as f:
            return int(f.read().strip())
    except:
        return 0

def read_pwm(n):
    try:
        with open(f"{FAN_HWMON}/pwm{n}") as f:
            return int(f.read().strip())
    except:
        return 0

def get_net_bytes():
    try:
        iface = sh("ip route | awk '/default/{print $5}' | head -1")
        if not iface:
            return 0, 0
        rx = int(sh(f"cat /sys/class/net/{iface}/statistics/rx_bytes"))
        tx = int(sh(f"cat /sys/class/net/{iface}/statistics/tx_bytes"))
        return rx, tx
    except:
        return 0, 0

def get_disks():
    disks = []
    devs = sorted([f"/dev/{d}" for d in os.listdir("/dev") if d.startswith("sd") and len(d) == 3])
    for dev in devs:
        name = sh(f"lsblk -d -n -o NAME {dev}").strip()
        size = sh(f"lsblk -d -n -o SIZE {dev}").strip()
        model = sh(f"smartctl -i {dev} | grep 'Device Model' | sed 's/.*: *//'")[:16]
        temp = sh(f"smartctl -A {dev} | grep -iE 'Temp.*Cel' | awk '{{print $10}}' | head -1")
        hours = sh(f"smartctl -A {dev} | grep Power_On_Hours | awk '{{print $10}}' | sed 's/h.*//'")
        realloc = sh(f"smartctl -A {dev} | grep Reallocated_Sector | awk '{{print $10}}'")
        pending = sh(f"smartctl -A {dev} | grep Current_Pending | awk '{{print $10}}'") or "0"
        health = "OK" if "PASSED" in sh(f"smartctl -H {dev}") else "FAIL"
        cycles = sh(f"smartctl -A {dev} | grep Power_Cycle | awk '{{print $10}}'")
        disks.append(dict(name=name, size=size, model=model, temp=temp,
                          hours=hours, realloc=realloc, pending=pending,
                          health=health, cycles=cycles))
    return disks

def detail_pages(d):
    warn = f" R:{d['realloc']}!" if d['realloc'] != "0" else ""
    return [
        f"{d['name']} {d['size']} {d['temp']}C {d['health']}{warn}",
        d['model'],
        f"{d['hours']}h Re:{d['realloc']} P:{d['pending']}",
        f"Cycles:{d['cycles']}",
    ]

def main():
    fd = setup_serial(PORT)
    lcd_backlight(fd, True)

    disks = get_disks()
    hostname = sh("hostname").upper()
    ndisks = len(disks)

    prev_rx, prev_tx = get_net_bytes()
    prev_net_time = time.time()
    rx_rate = "0K"
    tx_rate = "0K"
    prev_idle, prev_total = read_cpu_ticks()
    cpu_pct = "0"

    last_hw = 0
    auto_idx = 0
    mode = "auto"
    d_disk = 0
    d_page = 0
    last_btn = time.time()
    last_activity = time.time()
    screen_on = True
    hw_pages = []
    select_times = []

    def refresh_hw():
        nonlocal hw_pages, prev_rx, prev_tx, prev_net_time, rx_rate, tx_rate
        nonlocal prev_idle, prev_total, cpu_pct

        ct = sh(f"awk '{{printf \"%.0f\",$1/1000}}' {HWMON_CORETEMP}/temp1_input")
        ld = sh("awk '{print $1}' /proc/loadavg")
        mem_used = sh("free -m | awk '/Mem:/{print $3}'")
        mem_total = sh("free -m | awk '/Mem:/{print $2}'")
        ip = sh("hostname -I | awk '{print $1}'")
        uh, um = sh("awk '{h=int($1/3600);m=int(($1%3600)/60);print h,m}' /proc/uptime").split()
        up = f"{uh}h{um}m" if int(uh) > 0 else f"{um}m"
        dt = time.strftime("%H:%M %d/%b/%Y")
        board = sh(f"cat {HWMON_ACPI}/temp1_input 2>/dev/null")
        board = str(int(board)//1000) if board else "?"
        nic = sh(f"cat {HWMON_NIC}/temp1_input 2>/dev/null")
        nic = str(int(nic)//1000) if nic else "?"

        cur_idle, cur_total = read_cpu_ticks()
        d_idle = cur_idle - prev_idle
        d_total = cur_total - prev_total
        if d_total > 0:
            cpu_pct = f"{100 * (d_total - d_idle) / d_total:.0f}"
        prev_idle, prev_total = cur_idle, cur_total

        now = time.time()
        cur_rx, cur_tx = get_net_bytes()
        elapsed = now - prev_net_time
        if elapsed > 0:
            rx_rate = fmt_bytes(int((cur_rx - prev_rx) / elapsed))
            tx_rate = fmt_bytes(int((cur_tx - prev_tx) / elapsed))
        prev_rx, prev_tx = cur_rx, cur_tx
        prev_net_time = now

        ram = f"{fmt_thousands(mem_used)}/{fmt_thousands(mem_total)}M"
        fan1_rpm = read_fan(1)
        fan2_rpm = read_fan(2)
        fan2_pwm = read_pwm(2)
        fan2_pct = int(fan2_pwm / 255 * 100)

        hw_pages = [
            (hostname, ip),
            (f"CPU:{ct}C Load:{ld}", f"RAM {ram}"),
            (f"Uptime:{up}", f"{ndisks} disks online"),
            (f"CPU Use: {cpu_pct}%", dt),
            (f"Fan1: {fan1_rpm} RPM", f"Fan2: {fan2_rpm} RPM {fan2_pct}%"),
            (f"Net Rx:{rx_rate}", f"Net Tx:{tx_rate}"),
            (f"CPU:{ct}C Board:{board}C", f"NIC:{nic}C"),
        ]

    refresh_hw()

    def process_btn(btn):
        nonlocal mode, d_disk, d_page, last_btn, last_activity
        nonlocal screen_on, select_times

        now = time.time()
        last_activity = now

        if not screen_on:
            if btn in (0x01, 0x02):
                screen_on = True
                lcd_backlight(fd, True)
                mode = "auto"
            return

        if btn == 0x02:
            select_times.append(now)
            select_times[:] = [t for t in select_times if now - t < TRIPLE_WINDOW]
            if len(select_times) >= 3:
                select_times.clear()
                screen_on = False
                lcd_backlight(fd, False)
                lcd_write(fd, "", "")
                mode = "auto"
                return
        elif btn == 0x01:
            select_times.clear()
            if mode == "detail":
                d_page = (d_page + 1) % 4
            else:
                mode = "detail"
                d_disk = 0
                d_page = 0
            last_btn = now

    def check_pending_select():
        nonlocal mode, d_disk, d_page, last_btn, select_times
        now = time.time()
        if select_times and (now - select_times[-1]) > TRIPLE_WINDOW:
            select_times.clear()
            if mode == "auto":
                mode = "detail"
                d_disk = 0
                d_page = 0
            else:
                d_disk += 1
                d_page = 0
                if d_disk >= len(disks):
                    mode = "auto"
                    d_disk = 0
            last_btn = now

    while True:
        now = time.time()

        if screen_on and (now - last_activity) > SCREEN_TIMEOUT:
            screen_on = False
            lcd_backlight(fd, False)
            lcd_write(fd, "", "")
            mode = "auto"

        if now - last_hw > HW_REFRESH:
            refresh_hw()
            last_hw = now

        btn = read_button(fd)
        if btn is not None and btn != 0x00:
            process_btn(btn)

        check_pending_select()

        if not screen_on:
            time.sleep(0.3)
            continue

        if mode == "detail" and now - last_btn > DETAIL_TIMEOUT:
            mode = "auto"

        if mode == "auto":
            l1, l2 = hw_pages[auto_idx % len(hw_pages)]
            lcd_write(fd, l1, l2)
            auto_idx += 1
            for _ in range(int(PAGE_TIME / 0.2)):
                time.sleep(0.2)
                b = read_button(fd)
                if b is not None and b != 0x00:
                    process_btn(b)
                    check_pending_select()
                    if not screen_on or mode == "detail":
                        break
        else:
            pages = detail_pages(disks[d_disk])
            lcd_write(fd, f"[{disks[d_disk]['name']}] pg {d_page+1}/4", pages[d_page])
            time.sleep(0.3)

if __name__ == "__main__":
    main()
